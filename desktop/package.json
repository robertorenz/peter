{
  "name": "peter-and-the-wolf",
  "productName": "Peter and the Wolf",
  "version": "1.0.0",
  "description": "A storybook meadow game inspired by Prokofiev's Peter and the Wolf",
  "author": "Roberto Renz",
  "main": "main.js",
  "scripts": {
    "predist": "node copy-assets.js",
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.renz.peterandthewolf",
    "files": [
      "main.js",
      "index.html",
      "audio/**"
    ],
    "win": {
      "target": [
        "portable",
        "dir"
      ]
    },
    "portable": {
      "artifactName": "PeterAndTheWolf.exe"
    }
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  }
}
